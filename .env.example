# ============================================================
# VARIÁVEIS DO FRONTEND (Vite)
# Copie para .env e preencha com os valores do seu projeto
# ============================================================

VITE_SUPABASE_PROJECT_ID="seu-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."
VITE_SUPABASE_URL="https://seu-project-id.supabase.co"

# ============================================================
# SECRETS DAS EDGE FUNCTIONS
# Configure em: Supabase Dashboard → Edge Functions → Manage secrets
# https://supabase.com/dashboard/project/SEU_PROJECT_ID/settings/functions
# ============================================================

# Google Gemini — geração de relatórios com IA
# Obter em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=""

# PagBank — processamento de pagamentos
# Obter em: Painel PagBank → Configurações → Credenciais
PAGBANK_API_TOKEN=""
PAGBANK_PUBLIC_KEY=""

# PagBank — URL da API (OBRIGATÓRIO definir explicitamente)
# Teste:    https://sandbox.api.pagseguro.com
# Produção: https://api.pagseguro.com
PAGBANK_API_URL="https://api.pagseguro.com"

# PagBank — segredo para validar webhooks
# Defina uma senha forte e cadastre a mesma no webhook do PagBank
PAGBANK_WEBHOOK_SECRET=""

# Umami Analytics — sincronização de estatísticas
# Obter em: Painel Umami → Settings → API Keys
UMAMI_API_KEY=""
UMAMI_WEBSITE_ID="1d79c38e-f228-48c8-973f-4a8bfc15e0d2"

# ============================================================
# INJETADAS AUTOMATICAMENTE PELO SUPABASE (não configurar)
# ============================================================
# SUPABASE_URL
# SUPABASE_ANON_KEY
# SUPABASE_SERVICE_ROLE_KEY
